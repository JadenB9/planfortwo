{
  "name": "planfortwo",
  "private": true,
  "packageManager": "pnpm@9.1.0",
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "type-check": "turbo run type-check",
    "test": "turbo run test",
    "test:unit": "turbo run test:unit",
    "test:api": "turbo run test:api",
    "test:e2e": "turbo run test:e2e",
    "format": "prettier --write \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,jsx,json,md,css}\"",
    "db:push": "pnpm --filter @planfortwo/db db:push",
    "db:generate": "pnpm --filter @planfortwo/db db:generate",
    "db:migrate": "pnpm --filter @planfortwo/db db:migrate",
    "db:seed": "pnpm --filter @planfortwo/db db:seed",
    "db:studio": "pnpm --filter @planfortwo/db db:studio",
    "email:dev": "pnpm --filter @planfortwo/email dev",
    "clean": "turbo run clean && rm -rf node_modules",
    "prepare": "husky"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.6.14",
    "turbo": "^2.9.3",
    "typescript": "^5.9.3"
  },
  "lint-staged": {
    "*.{ts,tsx,js,jsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,css}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "qr-code-styling": "^1.9.2"
  },
  "pnpm": {
    "overrides": {
      "flatted": "^3.4.0",
      "prismjs": "^1.30.0",
      "esbuild": ">=0.25.0",
      "inngest>next": ">=16.1.7",
      "hono": "^4.12.12",
      "@hono/node-server": "^1.19.13",
      "vite": "^6.4.2"
    }
  }
}
