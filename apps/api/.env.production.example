# ── Railway Environment Variables (Production) ──
# Set these in Railway Dashboard > Service > Variables

# ── Supabase (Production) ──
DATABASE_URL=postgresql://postgres.YOUR_PROJECT_REF:PASSWORD@aws-0-us-east-1.pooler.supabase.com:6543/postgres

# ── Clerk (Production) ──
CLERK_SECRET_KEY=sk_live_XXXXX
CLERK_WEBHOOK_SECRET=whsec_XXXXX

# ── Stripe (Live) ──
STRIPE_SECRET_KEY=sk_live_XXXXX
STRIPE_WEBHOOK_SECRET=whsec_XXXXX
STRIPE_PRICE_ID=price_XXXXX

# ── Cloudflare R2 (Production) ──
CLOUDFLARE_ACCOUNT_ID=XXXXX
CLOUDFLARE_API_TOKEN=XXXXX
R2_ACCESS_KEY_ID=XXXXX
R2_SECRET_ACCESS_KEY=XXXXX
R2_BUCKET_NAME=planfortwo-prod

# ── Resend (Production) ──
RESEND_API_KEY=re_XXXXX

# ── Inngest (Production) ──
INNGEST_EVENT_KEY=XXXXX
INNGEST_SIGNING_KEY=signkey-XXXXX

# ── App Config ──
NEXT_PUBLIC_APP_URL=https://app.planfortwo.com
PORT=3001
NODE_ENV=production
